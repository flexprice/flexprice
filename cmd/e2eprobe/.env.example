# ════════════════════════════════════════════════════════════════
# REQUIRED — fill in
# ════════════════════════════════════════════════════════════════
export E2EPROBE_API_HOST=''
export E2EPROBE_API_KEY=''
export E2EPROBE_TENANT_ID=''
export E2EPROBE_ENVIRONMENT_ID=''

# ════════════════════════════════════════════════════════════════
# GLOBAL toggles
# ════════════════════════════════════════════════════════════════
export E2EPROBE_ENABLED=true                # master kill switch
export E2EPROBE_DRY_RUN=false               # set true to log mutations without executing
export E2EPROBE_EVENT_INGEST_RATE=1         # events/sec for the steady driver
export E2EPROBE_EVENT_INGEST_SEED=42        # deterministic ingest sequence (replayable)
export E2EPROBE_LISTENER_PORT=8765          # HTTP endpoint for the low-wallet webhook
export E2EPROBE_OTEL_ENABLED=false          # enable OTEL span emission
export E2EPROBE_HEARTBEAT_INTERVAL=1h       # heartbeat interval for the heartbeat check
export E2EPROBE_JANITOR_MAX_AGE=1h          # default 1h; raise if you want longer ephemeral lifetimes
export E2EPROBE_LOG_LEVEL=info              # debug|info|warn|error (default info); use debug to see per-tick checkpoints (analytics fetched, drop event ingested, webhook received, aggregation observed, startup grace, ...)

# ════════════════════════════════════════════════════════════════
# PER-CHECK enable + interval (all default to enabled)
# ════════════════════════════════════════════════════════════════
export E2EPROBE_CHECK_SEED_ENSURE_ENABLED=true
export E2EPROBE_CHECK_SEED_ENSURE_INTERVAL=6h

export E2EPROBE_CHECK_EVENT_INGEST_DRIVER_ENABLED=true
# (rate is controlled by E2EPROBE_EVENT_INGEST_RATE; interval ignored)

export E2EPROBE_CHECK_ANALYTICS_PROBE_ENABLED=true
export E2EPROBE_CHECK_ANALYTICS_PROBE_INTERVAL=2m

export E2EPROBE_CHECK_WALLET_BALANCE_PROBE_ENABLED=true
export E2EPROBE_CHECK_WALLET_BALANCE_PROBE_INTERVAL=2m

export E2EPROBE_CHECK_WALLET_DEBIT_VERIFICATION_ENABLED=true
export E2EPROBE_CHECK_WALLET_DEBIT_VERIFICATION_INTERVAL=20m

export E2EPROBE_CHECK_CYCLE_INVOICE_PROBE_ENABLED=true
export E2EPROBE_CHECK_CYCLE_INVOICE_PROBE_INTERVAL=15m

export E2EPROBE_CHECK_ENTITLEMENT_AND_USAGE_PROBE_ENABLED=true

export E2EPROBE_CHECK_CANCEL_CUSTOMER_FLOW_ENABLED=true
export E2EPROBE_CHECK_CANCEL_CUSTOMER_FLOW_INTERVAL=30m

export E2EPROBE_CHECK_SUBSCRIPTION_MODIFICATION_FLOW_ENABLED=true
export E2EPROBE_CHECK_SUBSCRIPTION_MODIFICATION_FLOW_INTERVAL=20m

export E2EPROBE_CHECK_LOW_WALLET_ALERT_LISTENER_ENABLED=true
# (listener is webhook-driven; interval ignored)

# LOW_BALANCE_ALERT_PROBE actively drives the alert-canary wallet across its
# low-balance thresholds and asserts the webhook lands within 2m (grace absorbs
# Kafka + Svix / native HTTP propagation delay). Missing webhooks page Slack
# via the existing reporter chain. Needs the canary wallet provisioned by
# SEED_ENSURE and the Flexprice-side webhook endpoint pointed at
# http://<probe-host>:E2EPROBE_LISTENER_PORT/webhook.
export E2EPROBE_CHECK_LOW_BALANCE_ALERT_PROBE_ENABLED=true
export E2EPROBE_CHECK_LOW_BALANCE_ALERT_PROBE_INTERVAL=5m

export E2EPROBE_CHECK_JANITOR_ENABLED=true
export E2EPROBE_CHECK_JANITOR_INTERVAL=1h

export E2EPROBE_CHECK_METER_AGGREGATION_PROBE_ENABLED=true
export E2EPROBE_CHECK_METER_AGGREGATION_PROBE_INTERVAL=3m

# ════════════════════════════════════════════════════════════════
# SLACK alerts — fill in to enable (leave unset to disable)
# ════════════════════════════════════════════════════════════════
export E2EPROBE_SLACK_WEBHOOK_URL=''
export E2EPROBE_SLACK_CHANNEL=''

# ════════════════════════════════════════════════════════════════
# OTEL export to SigNoz / Grafana Tempo / etc. — fill in to enable
# Honors standard OTLP env vars (no custom prefix)
# ════════════════════════════════════════════════════════════════
export OTEL_EXPORTER_OTLP_ENDPOINT=''
export OTEL_EXPORTER_OTLP_HEADERS='' # if collector needs auth
export OTEL_SERVICE_NAME=''
