      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "TERMINAL: SUCCESS\nevents: token.confirmed + payment.captured\n(same order_id covers both)\nINSERT PaymentMethod row (unique-index-backed, no\nentity_integration_mapping \u2014 PaymentMethod is the\nsole source of truth): gateway_method_id=token_id,\nmethod_details={max_amount, expire_at, status=confirmed,\nsecure.encrypted_gateway_method_id}\nMark THIS invoice PAID from that same payment\nAll future invoices \u2192 DIAGRAM 1 auto-charge flow",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "r176",
      "originalText": "TERMINAL: SUCCESS\nevents: token.confirmed + payment.captured\n(same order_id covers both)\nINSERT PaymentMethod row (unique-index-backed, no\nentity_integration_mapping \u2014 PaymentMethod is the\nsole source of truth): gateway_method_id=token_id,\nmethod_details={max_amount, expire_at, status=confirmed,\nsecure.encrypted_gateway_method_id}\nMark THIS invoice PAID from that same payment\nAll future invoices \u2192 DIAGRAM 1 auto-charge flow",
      "lineHeight": 1.25,
      "baseline": 14
    },
