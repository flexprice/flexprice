# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# Local value overrides — never package production secrets or env-specific values
values.local.yaml
values-prod.yaml
values-staging.yaml
values-dev.yaml
# CI/CD and scripting artifacts
provision.sh
*.sh
# Documentation that doesn't belong in the chart package
docs/
*.md
!README.md

