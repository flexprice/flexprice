{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "Asia/Kolkata",
  "schedule": ["before 9am on monday"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group Helm subchart dependency bumps into a single PR per chart minor",
      "matchManagers": ["helmv3"],
      "matchPaths": ["helm/flexprice/Chart.yaml"],
      "groupName": "helm subcharts",
      "schedule": ["before 9am on monday"]
    },
    {
      "description": "Group image-tag bumps in Helm values into one PR (chart-image-tags)",
      "matchManagers": ["helm-values", "regex"],
      "matchPaths": ["helm/**"],
      "groupName": "helm image tags",
      "schedule": ["before 9am on monday"]
    },
    {
      "description": "Group GitHub Actions bumps",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "schedule": ["before 9am on monday"]
    },
    {
      "description": "Auto-merge patch and minor for trusted base images",
      "matchPackageNames": [
        "alpine",
        "busybox",
        "curlimages/curl",
        "postgres"
      ],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Pin Bitnami subcharts to exact minor (allow patch + minor)",
      "matchManagers": ["helmv3"],
      "matchDepNames": ["postgresql", "kafka", "redis"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Hold majors for review",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"],
      "automerge": false
    }
  ],
  "regexManagers": [
    {
      "description": "Bump pinned image tags inside helm values files",
      "fileMatch": ["^helm/.*\\.ya?ml$"],
      "matchStrings": [
        "repository:\\s*(?<depName>[^\\s#]+)\\s*\\n\\s*tag:\\s*\"?(?<currentValue>[^\\s\"#]+)\"?"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "schedule": ["at any time"]
  }
}
